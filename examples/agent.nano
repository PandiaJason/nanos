name: "nanos-agent"
model:
  provider: "ollama"
  model_name: "qwen2.5-coder:0.5b"
  context_window: 4096
resources:
  memory: "4gb"
  max_steps: 10
permissions:
  fs_read:
    - "instruction.txt"
    - "/workspace/**"
  fs_write:
    - "secret.txt"
    - "/workspace/**"
  network: false
tools:
  - "fs_read"
  - "fs_write"
goal: "Read the file instruction.txt, find the secret code inside it, and write ONLY the secret code into a new file called secret.txt. Then call done."
