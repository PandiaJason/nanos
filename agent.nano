name: "pdf-summarizer"
model:
  path: "./models/tinyllama.gguf"
  context_window: 4096
resources:
  memory: "512mb"
  max_steps: 20
permissions:
  fs_read:
    - "/docs"
    - "/workspace/**"
    - "instruction.txt"
  fs_write:
    - "secret.txt"
  network: false
tools:
  - "fs_read"
  - "fs_write"
goal: "Read the file instruction.txt. Find the secret code and write it into a new file called secret.txt, then output the done action."
